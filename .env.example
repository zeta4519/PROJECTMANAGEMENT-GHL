# Server
PORT=3001
DB_PATH=./data/pm.db

# Webhook security (scegli una stringa random e incollala in GHL come header x-webhook-secret)
WEBHOOK_SECRET=cambia_questa_stringa_random

# GHL Location IDs (trovali in GHL → Settings → Business Info)
GHL_LOCATION_ACC1=il_tuo_location_id_stark
GHL_LOCATION_ACC2=il_tuo_location_id_azienda2

# Dev: punta il frontend al backend locale
VITE_API_URL=http://localhost:3001/api
